{
  "info": {
    "name": "WA Gateway SaaS",
    "description": "Postman collection untuk WhatsApp Gateway SaaS Laravel + Node WA. Isi collection variables: base_url, token, session_id, message_id.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "session_id",
      "value": ""
    },
    {
      "key": "message_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "WhatsApp Sessions",
      "item": [
        {
          "name": "Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.session_id) pm.collectionVariables.set('session_id', json.data.session_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nomor CS\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/wa/sessions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wa",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/wa/sessions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wa",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "Get QR",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/wa/sessions/{{session_id}}/qr",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wa",
                "sessions",
                "{{session_id}}",
                "qr"
              ]
            }
          }
        },
        {
          "name": "Get Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/wa/sessions/{{session_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wa",
                "sessions",
                "{{session_id}}",
                "status"
              ]
            }
          }
        },
        {
          "name": "List Groups",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/wa/sessions/{{session_id}}/groups",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wa",
                "sessions",
                "{{session_id}}",
                "groups"
              ]
            }
          }
        },
        {
          "name": "List Contacts",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/wa/sessions/{{session_id}}/contacts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wa",
                "sessions",
                "{{session_id}}",
                "contacts"
              ]
            }
          }
        },
        {
          "name": "Disconnect Session",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/wa/sessions/{{session_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "wa",
                "sessions",
                "{{session_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Text Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.message_id) pm.collectionVariables.set('message_id', json.data.message_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"target_type\": \"contact\",\n  \"to\": \"6281234567890\",\n  \"type\": \"text\",\n  \"message\": \"Halo dari WA Gateway\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/messages/send",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "messages",
                "send"
              ]
            }
          }
        },
        {
          "name": "Send Image Message",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"target_type\": \"contact\",\n  \"to\": \"6281234567890\",\n  \"type\": \"image\",\n  \"message\": \"Caption gambar\",\n  \"media_url\": \"https://example.com/image.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/messages/send",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "messages",
                "send"
              ]
            }
          }
        },
        {
          "name": "Message History",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/messages?session_id={{session_id}}&page=1&per_page=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "messages"
              ],
              "query": [
                {
                  "key": "session_id",
                  "value": "{{session_id}}"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
